<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_marginVertical="8dp"
    android:layout_height="wrap_content"
    android:paddingStart="8dp"
    android:paddingTop="8dp"
    android:background="@drawable/background_voyage">

    <TextView
        android:id="@+id/text_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="18sp"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="8dp"
        tools:text="Some voyage name" />

    <TextView
        android:id="@+id/text_caption_from"
        android:layout_width="60dp"
        android:gravity="end"
        android:layout_height="wrap_content"
        android:text="@string/from"
        android:textSize="18sp"
        app:layout_constraintBottom_toBottomOf="@+id/text_start_time"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/text_from_station" />
    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/text_from_station"
        tools:text="Port Baikal"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toBottomOf="@+id/text_name"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/text_caption_from"/>
    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/text_start_time"
        tools:text="01.01.2001 13:00"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toBottomOf="@+id/text_from_station"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toEndOf="@+id/text_caption_from"/>



    <TextView
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:id="@+id/text_caption_to"
        android:text="@string/to"
        android:gravity="end"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/text_to_station"
        app:layout_constraintBottom_toBottomOf="@+id/text_end_time"
        android:textSize="18sp"/>
    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/text_to_station"
        tools:text="Irkutsk Autostation"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@+id/text_start_time"
        android:layout_marginTop="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/text_caption_to"/>
    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/text_end_time"
        android:layout_marginEnd="8dp"
        tools:text="01.01.2001 13:00"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toBottomOf="@+id/text_to_station"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/text_caption_to"/>

    <TextView
        android:id="@+id/text_price"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:textColor="@color/black"
        android:textSize="24sp"
        android:layout_marginEnd="8dp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/text_to_station"
        app:layout_constraintTop_toBottomOf="@+id/text_start_time"
        tools:layout_editor_absoluteX="8dp"
        tools:text="3000 RUB" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/background_text_buy"
        android:paddingHorizontal="16dp"
        android:id="@+id/text_button_buy"
        android:paddingVertical="8dp"
        android:text="@string/buy"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:layout_marginTop="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/text_price" />
</androidx.constraintlayout.widget.ConstraintLayout>